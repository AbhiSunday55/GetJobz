rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.uid is string && data.email is string && data.displayName is string;
    }
    function isValidInterview(data) {
      return data.userId == request.auth.uid && data.role is string;
    }
    function isValidATSCheck(data) {
      return data.userId == request.auth.uid && data.score is number;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /interviews/{interviewId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidInterview(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidInterview(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /ats_checks/{checkId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidATSCheck(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }
  }
}
